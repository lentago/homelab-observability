      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "expr": "avg_over_time(probe_success{job=\"integrations/blackbox/lentago.dev\"}[24h])"
        }
      ]
    },
