      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "solidago-cloudwatch"
          },
          "refId": "A",
          "queryMode": "Metrics",
          "metricQueryType": 0,
          "metricEditorMode": 1,
          "expression": "SEARCH('{AWS/ApplicationELB,LoadBalancer,TargetGroup} MetricName=\"RequestCount\" \"solidago-dev-lentago-tg\"', 'Sum', 300)",
