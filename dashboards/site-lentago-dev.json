  "description": "Per-site health for lentago.dev (ECS service solidago-dev-lentago on the shared Solidago platform). Status row: outside-in blackbox probes from the lab Alloy (Mimir). Traffic/runtime rows: query-on-demand CloudWatch \u2014 every render bills GetMetricData; overnight gaps are the nightly DR teardown drill. ALB panels use SEARCH expressions on stable name fragments because TargetGroup/LoadBalancer dimension hashes rotate on the nightly rebuild. Refresh floor is 5m.",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Up",
      "description": "Outside-in HTTPS probe from the lab Alloy (30s).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 1
                },
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 0
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "justifyMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "expr": "probe_success{job=\"integrations/blackbox/lentago.dev\"}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
