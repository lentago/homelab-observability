                "matcher": {
                  "id": "byName",
                  "options": "Status"
                },
                "properties": [
                  {
                    "id": "mappings",
                    "value": [
                      {
                        "options": {
                          "0": {
                            "color": "red",
                            "index": 1,
                            "text": "DOWN"
                          },
                          "1": {
                            "color": "green",
                            "index": 0,
                            "text": "UP"
                          }
                        },
                        "type": "value"
                      }
