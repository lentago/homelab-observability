        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Host"
          }
        ]
      },
      "targets": [
        {
          "expr": "max by(instance)(up{job=\"node\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "100 * (1 - avg by(instance)(node_memory_MemAvailable_bytes) / avg by(instance)(node_memory_MemTotal_bytes))",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "100 - (avg by(instance)(node_filesystem_avail_bytes{mountpoint=~\"/|/rootfs\",fstype!~\"tmpfs|overlay\"}) / avg by(instance)(node_filesystem_size_bytes{mountpoint=~\"/|/rootfs\",fstype!~\"tmpfs|overlay\"}) * 100)",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "expr": "max by(instance)(node_load1)",
          "format": "table",
          "instant": true,
          "refId": "E"
        },
        {
          "expr": "max by(instance)(node_hwmon_temp_celsius) * 9 / 5 + 32",
          "format": "table",
          "instant": true,
          "refId": "F"
        },
        {
          "expr": "max by(instance)(time() - node_boot_time_seconds)",
          "format": "table",
          "instant": true,
          "refId": "G"
        }
      ],
      "title": "Fleet Scoreboard — one row per host",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5,
              "Value #F": 6,
              "Value #G": 7,
              "instance": 0
            },
            "renameByName": {
              "Value #A": "Up",
              "Value #B": "CPU %",
              "Value #C": "RAM %",
              "Value #D": "Root %",
              "Value #E": "Load1",
              "Value #F": "Temp °F",
              "Value #G": "Uptime",
              "instance": "Host"
            }
          }
        }
      ],
      "type": "table"
