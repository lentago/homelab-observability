                "matcher": {
                  "id": "byName",
                  "options": "Latency (ms)"
                },
                "properties": [
                  {
                    "id": "unit",
                    "value": "ms"
                  },
                  {
                    "id": "decimals",
                    "value": 1
                  }
                ]
              }
