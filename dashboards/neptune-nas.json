{
  "uid": "firewalla-neptune-nas",
  "title": "Neptune NAS",
  "description": "Near-real-time activity for the Neptune NAS (Ugreen DXP, Intel N100, 2x4TB md-RAID1 -> btrfs /volume1). node_exporter (job=node, instance=neptune) for CPU/memory/disk/network/RAID, enriched with Home Assistant UGreen sensors for per-disk temps and fan. Scrape interval is 30s.",
  "tags": ["homelab", "nas", "neptune", "storage", "node-exporter"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 0,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m"]
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health & Capacity",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "NAS Online",
      "description": "node_exporter scrape heartbeat for neptune (1 = scraped successfully in the last interval)",
      "gridPos": { "x": 0, "y": 1, "w": 3, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"node\", instance=\"neptune\"}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OFFLINE", "color": "red" },
                "1": { "text": "ONLINE", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Uptime",
      "description": "Time since last boot",
      "gridPos": { "x": 3, "y": 1, "w": 3, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - node_boot_time_seconds{instance=\"neptune\"}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "text" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "text" }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "CPU",
      "description": "CPU utilization across all cores (100% - idle)",
      "gridPos": { "x": 6, "y": 1, "w": 3, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg(irate(node_cpu_seconds_total{instance=\"neptune\", mode=\"idle\"}[$__rate_interval])) * 100)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 60, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Memory",
      "description": "Memory in use (MemTotal - MemAvailable)",
      "gridPos": { "x": 12, "y": 1, "w": 3, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - node_memory_MemAvailable_bytes{instance=\"neptune\"} / node_memory_MemTotal_bytes{instance=\"neptune\"}) * 100",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "vertical",
        "displayMode": "lcd",
        "valueMode": "color",
        "showUnfilled": true
      }
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Volume /volume1",
      "description": "btrfs data volume (RAID1 pool) capacity used",
      "gridPos": { "x": 15, "y": 1, "w": 3, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (node_filesystem_avail_bytes{instance=\"neptune\", mountpoint=\"/volume1\"} / node_filesystem_size_bytes{instance=\"neptune\", mountpoint=\"/volume1\"} * 100)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "vertical",
        "displayMode": "lcd",
        "valueMode": "color",
        "showUnfilled": true
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "RAID1 (md1)",
      "description": "Array health: HEALTHY when active disks == required disks for md1, otherwise DEGRADED",
      "gridPos": { "x": 18, "y": 1, "w": 3, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "scalar(node_md_disks{instance=\"neptune\", device=\"md1\", state=\"active\"}) == bool scalar(node_md_disks_required{instance=\"neptune\", device=\"md1\"})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DEGRADED", "color": "red" },
                "1": { "text": "HEALTHY", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 8,
      "type": "gauge",
      "title": "CPU Temp",
      "description": "CPU package temperature (coretemp)",
      "gridPos": { "x": 9, "y": 1, "w": 3, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "node_hwmon_temp_celsius{instance=\"neptune\", chip=\"platform_coretemp_0\", sensor=\"temp1\"}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Fan",
      "description": "Chassis fan speed (from Home Assistant UGreen NAS integration)",
      "gridPos": { "x": 21, "y": 1, "w": 3, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "homeassistant_sensor_unit_rpm{entity=\"sensor.ugreen_nas_device_fan\"}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rotrpm",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "CPU",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU Utilization by Mode",
      "description": "Per-mode CPU busy time as a share of total capacity (idle excluded); stack height = total CPU busy %",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (irate(node_cpu_seconds_total{instance=\"neptune\", mode!=\"idle\"}[$__rate_interval])) * 100 / scalar(count(count by (cpu) (node_cpu_seconds_total{instance=\"neptune\"})))",
          "legendFormat": "{{mode}}"
        }
      ],
      "interval": "30s",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 25,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "tooltip": false, "vis": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Load Average",
      "description": "System load average (1/5/15 min). Threshold line at core count (4).",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "node_load1{instance=\"neptune\"}", "legendFormat": "1m" },
        { "refId": "B", "expr": "node_load5{instance=\"neptune\"}", "legendFormat": "5m" },
        { "refId": "C", "expr": "node_load15{instance=\"neptune\"}", "legendFormat": "15m" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "tooltip": false, "vis": false, "legend": false },
            "thresholdsStyle": { "mode": "line" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 4, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 13,
      "type": "row",
      "title": "Memory & Storage Capacity",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Memory Breakdown",
      "description": "Used / cache+buffers / free, stacked to MemTotal",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_MemTotal_bytes{instance=\"neptune\"} - node_memory_MemAvailable_bytes{instance=\"neptune\"}",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "node_memory_Cached_bytes{instance=\"neptune\"} + node_memory_Buffers_bytes{instance=\"neptune\"}",
          "legendFormat": "cache + buffers"
        },
        {
          "refId": "C",
          "expr": "node_memory_MemFree_bytes{instance=\"neptune\"}",
          "legendFormat": "free"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 25,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "tooltip": false, "vis": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "free" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "used" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Volume /volume1 — Used vs Free",
      "description": "btrfs RAID1 data volume usage over time (stacked to total capacity)",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "node_filesystem_size_bytes{instance=\"neptune\", mountpoint=\"/volume1\"} - node_filesystem_avail_bytes{instance=\"neptune\", mountpoint=\"/volume1\"}",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "node_filesystem_avail_bytes{instance=\"neptune\", mountpoint=\"/volume1\"}",
          "legendFormat": "free"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 25,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "tooltip": false, "vis": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "free" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "used" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "max"] }
      }
    },
    {
      "id": 16,
      "type": "row",
      "title": "Disk Activity",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Disk Throughput",
      "description": "Read/write bytes per second per device (sda, sdb = physical members; md1 = RAID1 array)",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "irate(node_disk_read_bytes_total{instance=\"neptune\", device=~\"sd[ab]|md1\"}[$__rate_interval])",
          "legendFormat": "{{device}} read"
        },
        {
          "refId": "B",
          "expr": "irate(node_disk_written_bytes_total{instance=\"neptune\", device=~\"sd[ab]|md1\"}[$__rate_interval])",
          "legendFormat": "{{device}} write"
        }
      ],
      "interval": "30s",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "tooltip": false, "vis": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Disk IOPS",
      "description": "Completed read/write operations per second per device",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "irate(node_disk_reads_completed_total{instance=\"neptune\", device=~\"sd[ab]|md1\"}[$__rate_interval])",
          "legendFormat": "{{device}} read"
        },
        {
          "refId": "B",
          "expr": "irate(node_disk_writes_completed_total{instance=\"neptune\", device=~\"sd[ab]|md1\"}[$__rate_interval])",
          "legendFormat": "{{device}} write"
        }
      ],
      "interval": "30s",
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "tooltip": false, "vis": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Disk Utilization",
      "description": "Percent of time each device was busy servicing I/O",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "irate(node_disk_io_time_seconds_total{instance=\"neptune\", device=~\"sd[ab]|md1\"}[$__rate_interval]) * 100",
          "legendFormat": "{{device}}"
        }
      ],
      "interval": "30s",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
