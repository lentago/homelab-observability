          "expr": "irate(node_disk_read_time_seconds_total{instance=\"neptune\", device=~\"sd[ab]|md1\"}[$__rate_interval]) / clamp_min(irate(node_disk_reads_completed_total{instance=\"neptune\", device=~\"sd[ab]|md1\"}[$__rate_interval]), 1) * 1000",
          "legendFormat": "{{device}} read"
        },
        {
