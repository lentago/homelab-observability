{
  "uid": "claude-runner-fleet",
  "title": "Claude Runner Fleet",
  "description": "Claude Runner Fleet observability: per-job cost, turns, and runtime from Loki job_complete events, plus a live open-PR review queue pulled from the GitHub API via the Infinity datasource.",
  "tags": [
    "claude-runner",
    "lentago-lab"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({job=\"claude_runner\"}, project)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | status=\"success\"",
        "hide": false,
        "iconColor": "green",
        "name": "Task ended (success)",
        "step": "60s",
        "tagKeys": "project,runid",
        "textFormat": "done {{.project}} #{{.runid}}",
        "titleFormat": "Task complete",
        "type": "default"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | status=\"failed\"",
        "hide": false,
        "iconColor": "red",
        "name": "Task ended (failed)",
        "step": "60s",
        "tagKeys": "project,runid",
        "textFormat": "failed {{.project}} #{{.runid}}",
        "titleFormat": "Task failed",
        "type": "default"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_started\"",
        "hide": false,
        "iconColor": "blue",
        "name": "Task started",
        "step": "60s",
        "tagKeys": "project,runid",
        "textFormat": "start {{.project}} #{{.runid}}",
        "titleFormat": "Task started",
        "type": "default"
      }
    ]
  },
  "panels": [
    {
      "id": 10,
      "type": "timeseries",
      "title": "Offload \u2014 runners underway vs local sessions live",
      "description": "The offload picture in one view: overlaid (not stacked) so you can watch local interactive sessions wind DOWN as the bullpen fleet winds UP. \"Runners underway\" = distinct busy bullpen workers (job_running heartbeat, 15s window). \"Local sessions live\" = distinct top-level local Claude Code sessions (session_running heartbeat, 2m window). Both are counts of concurrent work; where the orange falls and the blue rises is the handoff.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Runners underway"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Local sessions live"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "count(max by (worker) (count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_running\" [15s]) > bool 0)) or vector(0)",
          "legendFormat": "Runners underway"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "sum(max by (worker, session_id) (count_over_time({job=\"claude_local\"} | json | event=\"session_running\" [2m]) > bool 0)) or vector(0)",
          "legendFormat": "Local sessions live"
        }
      ]
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Total spend (range)",
      "description": "Runner + local combined spend over the dashboard range (job_complete cost_usd from the fleet plus session_complete cost_usd from local sessions).",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(sum_over_time({job=~\"claude_runner|claude_local\"} | json | event=~\"job_complete|session_complete\" | unwrap cost_usd [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Combined spend over time (runners + local)",
      "description": "Fleet and local spend stacked in one view \u2014 the stack height is the combined per-bucket spend. Per-project breakdowns for each side remain in their own panels below.",
      "gridPos": {
        "x": 6,
        "y": 12,
        "w": 18,
        "h": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 70
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Runners"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Local"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "sum(sum_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | unwrap cost_usd [$__auto])) or vector(0)",
          "legendFormat": "Runners"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "sum(sum_over_time({job=\"claude_local\"} | json | event=\"session_complete\" | unwrap cost_usd [$__auto])) or vector(0)",
          "legendFormat": "Local"
        }
      ]
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Jobs (range)",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Spend (range)",
      "gridPos": {
        "x": 6,
        "y": 18,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(sum_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | unwrap cost_usd [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Success rate",
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(count_over_time({job=\"claude_runner\", status=\"success\", project=~\"$project\"} | json | event=\"job_complete\" [$__range])) / sum(count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" [$__range])) or vector(1)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "PRs opened (range)",
      "gridPos": {
        "x": 18,
        "y": 18,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | pr_url!=\"\" [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Jobs over time by status",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 70
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "sum by (status) (count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" [$__auto])) or label_replace(vector(0), \"status\", \"none\", \"\", \"\")",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Spend over time by project",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 70
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "sum by (project) (sum_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | unwrap cost_usd [$__auto])) or vector(0)",
          "legendFormat": "{{project}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Job duration (avg / max)",
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 24,
        "h": 8
      },
      "datasource": {
