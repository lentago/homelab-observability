          },
          "queryType": "range",
          "expr": "max_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | unwrap duration_sec [$__auto]) or vector(0)",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Recent jobs",
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | line_format \"{{.status}} {{.project}} {{.model}} ${{.cost_usd}} {{.num_turns}}turns {{.duration_sec}}s {{.runid}}\""
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Open agent PRs (awaiting local review)",
      "description": "Live open-PR review queue from the GitHub Search API via the Infinity datasource: currently-open PRs authored by lentago-claude-runner[bot] across the Lentago Labs org, oldest first. Reflects real state \u2014 merged/closed PRs drop off. The Loki job_complete stream records pr_url only at open time and never observes the later merge, so it cannot track which PRs are still open.",
      "gridPos": {
        "x": 0,
        "y": 54,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "infinity"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Repo"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "regex",
                    "options": {
                      "pattern": ".*/(.+)$",
                      "result": {
                        "text": "$1"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "PR"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Title"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open PR on GitHub",
                    "url": "${__data.fields.url}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Opened"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeFromNow"
              },
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "url"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "infinity"
          },
          "type": "json",
          "source": "url",
          "format": "table",
          "parser": "backend",
          "url": "https://api.github.com/search/issues?q=is:pr+is:open+org:lentago+author:app/lentago-claude-runner&sort=created&order=asc&per_page=100",
          "url_options": {
            "method": "GET"
          },
          "root_selector": "items",
          "columns": [
            {
              "selector": "repository_url",
              "text": "Repo",
              "type": "string"
            },
            {
              "selector": "number",
              "text": "PR",
              "type": "number"
            },
            {
              "selector": "title",
              "text": "Title",
              "type": "string"
            },
            {
              "selector": "created_at",
              "text": "Opened",
              "type": "timestamp"
            },
            {
              "selector": "html_url",
              "text": "url",
              "type": "string"
            }
          ]
        }
      ]
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Stream of consciousness \u2014 claude-runner",
      "description": "Live, near-real-time reasoning for bullpen worker claude-runner. One always-present pane per fleet runner (not gated on recent activity, so an idle or not-yet-deployed worker shows an empty pane rather than vanishing). Tool-call noise is suppressed: tool-only turns are dropped and the trailing \"[TOOL] ...\" tag is stripped from mixed turns, leaving just the narration. Scrubbed for offsite egress (no thinking, no tool inputs). Filter by project with $project. For true websocket tailing, open this query in Explore.",
      "gridPos": {
        "x": 0,
        "y": 61,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "{job=\"claude_transcript\", worker=\"claude-runner\", project=~\"$project\"} !~ `^\\[TOOL\\]` | line_format `{{ regexReplaceAll \"\\\\s*\\\\[TOOL\\\\].*\" __line__ \"\" }}`"
        }
      ]
    },
    {
      "id": 13,
      "type": "logs",
      "title": "Stream of consciousness \u2014 claude-runner-2",
      "description": "Live, near-real-time reasoning for bullpen worker claude-runner-2. One always-present pane per fleet runner (not gated on recent activity, so an idle or not-yet-deployed worker shows an empty pane rather than vanishing). Tool-call noise is suppressed: tool-only turns are dropped and the trailing \"[TOOL] ...\" tag is stripped from mixed turns, leaving just the narration. Scrubbed for offsite egress (no thinking, no tool inputs). Filter by project with $project. For true websocket tailing, open this query in Explore.",
      "gridPos": {
        "x": 0,
        "y": 71,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
