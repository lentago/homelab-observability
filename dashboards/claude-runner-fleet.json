{
  "uid": "claude-runner-fleet",
  "title": "Claude Runner Fleet",
  "description": "Claude Runner Fleet observability: per-job cost, turns, and runtime from Loki job_complete events, plus a live open-PR review queue pulled from the GitHub API via the Infinity datasource.",
  "tags": [
    "claude-runner",
    "homelab"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({job=\"claude_runner\"}, project)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "worker",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({job=\"claude_transcript\"}, worker)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | status=\"success\"",
        "hide": false,
        "iconColor": "green",
        "name": "Task ended (success)",
        "step": "60s",
        "tagKeys": "project,runid",
        "textFormat": "done {{.project}} #{{.runid}}",
        "titleFormat": "Task complete",
        "type": "default"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | status=\"failed\"",
        "hide": false,
        "iconColor": "red",
        "name": "Task ended (failed)",
        "step": "60s",
        "tagKeys": "project,runid",
        "textFormat": "failed {{.project}} #{{.runid}}",
        "titleFormat": "Task failed",
        "type": "default"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_started\"",
        "hide": false,
        "iconColor": "blue",
        "name": "Task started",
        "step": "60s",
        "tagKeys": "project,runid",
        "textFormat": "start {{.project}} #{{.runid}}",
        "titleFormat": "Task started",
        "type": "default"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Jobs (range)",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Spend (range)",
      "gridPos": {
        "x": 6,
        "y": 12,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(sum_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | unwrap cost_usd [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Success rate",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(count_over_time({job=\"claude_runner\", status=\"success\", project=~\"$project\"} | json | event=\"job_complete\" [$__range])) / sum(count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" [$__range])) or vector(1)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "PRs opened (range)",
      "gridPos": {
        "x": 18,
        "y": 12,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | pr_url!=\"\" [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Jobs over time by status",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 70
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "sum by (status) (count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" [$__auto])) or vector(0)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Spend over time by project",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 70
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "sum by (project) (sum_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | unwrap cost_usd [$__auto])) or vector(0)",
          "legendFormat": "{{project}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Job duration (avg / max)",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "avg_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | unwrap duration_sec [$__auto]) or vector(0)",
          "legendFormat": "avg"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "max_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | unwrap duration_sec [$__auto]) or vector(0)",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Recent jobs",
      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | line_format \"{{.status}} {{.project}} {{.model}} ${{.cost_usd}} {{.num_turns}}turns {{.duration_sec}}s {{.runid}}\""
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Runners underway",
      "description": "Concurrent busy workers from the bullpen run-job heartbeat (event=\"job_running\", pushed to Loki every ~10s while a job is in flight). Counts distinct busy workers by worker label over a 15s window, so the line height is the number of workers underway at once (ceiling = number of single-threaded workers). Keying on worker (not runid) avoids over-counting during back-to-back job handoffs on the same worker. Gaps (height 0) are idle. Empty until the heartbeat ships from the workers and a job runs.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 60,
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "count(max by (worker) (count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_running\" [15s]) > bool 0)) or vector(0)",
          "legendFormat": "runners underway"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Local sessions live",
      "description": "Distinct top-level Claude Code sessions active per worker in the last 2 min (event=\"session_running\" heartbeats, ~30s cadence). Subagents roll up into their parent session — each band is one worker, height is how many separate sessions are churning. Gaps are idle/closed. Empty until a local session runs with the heartbeat hook installed.",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 60,
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "sum by (worker) (\n  max by (worker, session_id) (\n    count_over_time({job=\"claude_local\"} | json | event=\"session_running\" [2m]) > bool 0\n  )\n)",
          "legendFormat": "{{worker}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Open agent PRs (awaiting local review)",
      "description": "Live open-PR review queue from the GitHub Search API via the Infinity datasource: currently-open PRs authored by pitzilabs-claude-runner[bot] across the PitziLabs org, oldest first. Reflects real state \u2014 merged/closed PRs drop off. The Loki job_complete stream records pr_url only at open time and never observes the later merge, so it cannot track which PRs are still open.",
      "gridPos": {
        "x": 0,
        "y": 48,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "infinity"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Repo"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "regex",
                    "options": {
                      "pattern": ".*/(.+)$",
                      "result": {
                        "text": "$1"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "PR"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Title"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open PR on GitHub",
                    "url": "${__data.fields.url}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Opened"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeFromNow"
              },
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "url"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "infinity"
          },
          "type": "json",
          "source": "url",
          "format": "table",
          "parser": "backend",
          "url": "https://api.github.com/search/issues?q=is:pr+is:open+org:PitziLabs+author:app/pitzilabs-claude-runner&sort=created&order=asc&per_page=100",
          "url_options": {
            "method": "GET"
          },
          "root_selector": "items",
          "columns": [
            {
              "selector": "repository_url",
              "text": "Repo",
              "type": "string"
            },
            {
              "selector": "number",
              "text": "PR",
              "type": "number"
            },
            {
              "selector": "title",
              "text": "Title",
              "type": "string"
            },
            {
              "selector": "created_at",
              "text": "Opened",
              "type": "timestamp"
            },
            {
              "selector": "html_url",
              "text": "url",
              "type": "string"
            }
          ]
        }
      ]
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Stream of consciousness \u2014 $worker",
      "description": "Live, near-real-time reasoning for each bullpen worker \u2014 one pane per worker, repeated horizontally by the $worker variable (maxPerRow: 3). Each assistant turn's narration and tool names are streamed from the workers' Claude Code session transcripts via Alloy (job=\"claude_transcript\"). Scrubbed for offsite egress: thinking blocks and tool INPUTS are dropped; only text and tool names are shipped. An idle worker shows an empty pane. Filter by project with the $project variable. For true websocket tailing, open this query in Explore.",
      "gridPos": {
        "x": 0,
        "y": 55,
        "w": 8,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "{job=\"claude_transcript\", worker=\"$worker\", project=~\"$project\"}"
        }
      ],
      "repeat": "worker",
      "repeatDirection": "h",
      "maxPerRow": 3
    },
    {
      "id": 100,
      "type": "row",
      "title": "Local sessions \u2014 interactive (source=\"local\")",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 65,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Local sessions (range)",
      "gridPos": {
        "x": 0,
        "y": 66,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
