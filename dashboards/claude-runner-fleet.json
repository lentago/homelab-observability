{
  "uid": "claude-runner-fleet",
  "title": "Claude Runner Fleet",
  "description": "Claude Runner Fleet observability: per-job cost, turns, and runtime from Loki job_complete events, plus a live open-PR review queue pulled from the GitHub API via the Infinity datasource.",
  "tags": [
    "claude-runner",
    "lentago-lab"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({job=\"claude_runner\"}, project)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | status=\"success\"",
        "hide": false,
        "iconColor": "green",
        "name": "Task ended (success)",
        "step": "60s",
        "tagKeys": "project,runid",
        "textFormat": "done {{.project}} #{{.runid}}",
        "titleFormat": "Task complete",
        "type": "default"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" | status=\"failed\"",
        "hide": false,
        "iconColor": "red",
        "name": "Task ended (failed)",
        "step": "60s",
        "tagKeys": "project,runid",
        "textFormat": "failed {{.project}} #{{.runid}}",
        "titleFormat": "Task failed",
        "type": "default"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_started\"",
        "hide": false,
        "iconColor": "blue",
        "name": "Task started",
        "step": "60s",
        "tagKeys": "project,runid",
        "textFormat": "start {{.project}} #{{.runid}}",
        "titleFormat": "Task started",
        "type": "default"
      }
    ]
  },
  "panels": [
    {
      "id": 10,
      "type": "timeseries",
      "title": "Offload \u2014 concurrent runs (stacked, colored by model)",
      "description": "Concurrent Claude work, stacked so the total height is everything running at once. Headless runner runs are broken out and colored by model (opus / sonnet / haiku / fable / default) from the job_running heartbeat \u2014 distinct busy workers per model, 15s window. Local interactive sessions stack as a single grey 'local' band (session_running heartbeat, 2m window); the live heartbeat carries no model, so local runs are not model-attributed here. Where the local band falls and the model-colored runner bands rise is the offload handoff.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 35,
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "opus"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "sonnet"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "haiku"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "fable"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "default"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "local"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#808080"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "sum by (model) (max by (worker, model) (count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_running\" [15s]) > bool 0))",
          "legendFormat": "{{model}}"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "range",
          "expr": "sum(max by (worker, session_id) (count_over_time({job=\"claude_local\"} | json | event=\"session_running\" [2m]) > bool 0)) or vector(0)",
          "legendFormat": "local"
        }
      ]
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Total spend (range)",
      "description": "Runner + local combined spend over the dashboard range (job_complete cost_usd from the fleet plus session_complete cost_usd from local sessions).",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(sum_over_time({job=~\"claude_runner|claude_local\"} | json | event=~\"job_complete|session_complete\" | unwrap cost_usd [$__range])) or vector(0)"
        }
      ]
    },
