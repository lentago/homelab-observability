      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(count_over_time({job=\"claude_runner\", status=\"success\", project=~\"$project\"} | json | event=\"job_complete\" [$__range])) / sum(count_over_time({job=\"claude_runner\", project=~\"$project\"} | json | event=\"job_complete\" [$__range])) or vector(1)"
        }
      ]
    },
