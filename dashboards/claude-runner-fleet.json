          },
          "queryType": "instant",
          "expr": "sum(count_over_time({job=\"claude_local\"} | json | event=\"session_complete\" [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Local spend (range)",
      "gridPos": {
        "x": 6,
        "y": 66,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "decimals": 2
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "queryType": "instant",
          "expr": "sum(sum_over_time({job=\"claude_local\"} | json | event=\"session_complete\" | unwrap cost_usd [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Local turns (range)",
      "gridPos": {
        "x": 12,
        "y": 66,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
