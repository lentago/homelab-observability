    {
      "id": 23,
      "type": "stat",
      "title": "Network Health",
      "gridPos": {
        "x": 12,
        "y": 2,
        "w": 12,
        "h": 2
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(probe_success{job=\"icmp_ping\"}) / count(probe_success{job=\"icmp_ping\"})) * 100",
          "legendFormat": "Network Health",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
