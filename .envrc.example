# Copy to .envrc, fill in real values, then run `direnv allow`.
# .envrc is gitignored; this template (.envrc.example) is committed.
#
# Generate the Grafana Cloud service account token at:
#   https://pitzilabs.grafana.net → Administration → Users and access → Service accounts
# Generate the Alloy access policy tokens at:
#   https://grafana.com → Account → Access Policies (metrics:write, logs:write)

# Grafana Cloud stack
export GRAFANA_URL="https://pitzilabs.grafana.net"

# Service account token for the pitzilabs stack.
# Used by:
#   - Terraform / grafana provider (reads GRAFANA_AUTH)
#   - grafana-assistant CLI       (reads GRAFANA_SA_TOKEN)
# Same value; we just alias it under both names.
export GRAFANA_SA_TOKEN="glsa_REPLACE_ME"
export GRAFANA_AUTH="$GRAFANA_SA_TOKEN"

# Alloy → Grafana Cloud Mimir (metrics) — access policy token with metrics:write
# export GRAFANA_CLOUD_METRICS_USER="2123456"
# export GRAFANA_CLOUD_METRICS_TOKEN="glc_REPLACE_ME_METRICS"
# export GRAFANA_CLOUD_METRICS_URL="https://prometheus-prod-XX-prod-us-east-X.grafana.net/api/prom/push"

# Alloy → Grafana Cloud Loki (logs) — access policy token with logs:write
# export GRAFANA_CLOUD_LOGS_USER="1234567"
# export GRAFANA_CLOUD_LOGS_TOKEN="glc_REPLACE_ME_LOGS"
# export GRAFANA_CLOUD_LOGS_URL="https://logs-prod-XXX.grafana.net/loki/api/v1/push"
